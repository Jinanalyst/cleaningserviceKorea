# 손길 환경변수 예시 — 실제 값은 .env.local (로컬) 및 Vercel 프로젝트 환경변수에 설정하세요.

# Supabase 프로젝트 URL (Project Settings → API → Project URL)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service_role 비밀 키 (Project Settings → API → service_role)
# ⚠️ 절대 클라이언트에 노출하지 말 것. 서버(라우트 핸들러)에서만 사용됩니다.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
