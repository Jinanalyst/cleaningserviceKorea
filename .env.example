# 손길 환경변수 예시 — 실제 값은 .env.local (로컬) 및 Vercel 프로젝트 환경변수에 설정하세요.

# Supabase 프로젝트 URL (Project Settings → API → Project URL)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service_role 비밀 키 (Project Settings → API → service_role)
# ⚠️ 절대 클라이언트에 노출하지 말 것. 서버(라우트 핸들러)에서만 사용됩니다.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 클라이언트(브라우저)용 공개 값 — 구글 로그인(Supabase Auth)에 사용
# NEXT_PUBLIC_ 접두사는 브라우저에 노출되며, anon 키는 공개되어도 안전합니다.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# 운영자(관리자) 이메일 — 콤마 구분. 이 이메일 계정만 /admin 접근 가능.
ADMIN_EMAILS=admin@example.com
